# tablet-dash bind patch (Option B)
#
# server.py hardcodes `app.run(host="0.0.0.0", ...)`. This makes it honour
# TABLET_DASH_HOST (default 127.0.0.1), set by the replacement tablet-dash.service.
#
# READ THIS FIRST: the tablet (192.168.0.160) loads this dashboard over the LAN and
# is NOT on the tailnet, so binding 127.0.0.1 (or the tailscale IP) will BLACK OUT
# the tablet display. For tablet-dash, Option A (firewall scoped to 192.168.0.160)
# is the recommended path; use this patch only if you also move the tablet onto
# Tailscale, or accept the dashboard going localhost-only.
#
# Apply with:  cd ~/tablet-assistant && git apply /path/to/tablet-dash-server.py.patch
# (or hand-edit the two lines shown below).

--- a/server.py
+++ b/server.py
@@ -1,5 +1,6 @@
 #!/usr/bin/env python3
 """Tablet dashboard server: calendar + tasks + assistant feed on one page."""
+import os
 import json
 import threading
 import time
@@ -107,4 +108,4 @@


 if __name__ == "__main__":
-    app.run(host="0.0.0.0", port=PORT)
+    app.run(host=os.environ.get("TABLET_DASH_HOST", "127.0.0.1"), port=PORT)
